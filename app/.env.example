# Ezyride — environment template. Copy to .env.local and fill in.
# .env.local is gitignored; never commit real secrets.

# Local Postgres + PostGIS (matches docker-compose.yml)
DATABASE_URL=postgresql://ezyride:ezyride@localhost:5433/ezyride?schema=public

# Auth — generate a strong random value for anything beyond local dev
JWT_SECRET=change_me

# Required to register a chauffeur account (public signup is riders-only).
# Hand this out during driver onboarding; leave unset to disable driver signup.
DRIVER_INVITE_CODE=change_me

# External data providers
AVIATIONSTACK_API_KEY=
FINNHUB_API_KEY=

# Client-side map token (public)
NEXT_PUBLIC_MAPBOX_TOKEN=
