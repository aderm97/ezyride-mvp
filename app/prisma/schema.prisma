datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}



model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String
  lat       Float?
  lng       Float?
  isActive  Boolean  @default(false) // For driver online status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ridesAsRider  Ride[] @relation("RiderRelation")
  ridesAsDriver Ride[] @relation("DriverRelation")
}

model Ride {
  id         String     @id @default(uuid())
  riderId    String
  driverId   String?
  status     String     @default("PENDING")
  tier       String     @default("standard")
  airportCode String?
  terminal    String?
  pickupLat  Float
  pickupLng  Float
  dropoffLat Float
  dropoffLng Float
  fare       Float      @default(0.0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  rider  User  @relation("RiderRelation", fields: [riderId], references: [id])
  driver User? @relation("DriverRelation", fields: [driverId], references: [id])
}
